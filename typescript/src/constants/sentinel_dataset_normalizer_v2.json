{
  "metadata": {
    "name": "SENTINEL MX Dataset — Normalizer Layer v2",
    "version": "2.0.0",
    "description": "Capa de normalización lingüística (Tier 0) con arquitectura lexicon+features+rules, compatible y paralela a v4. Resuelve el problema de escritura informal, analfabetismo funcional y variantes fonéticas del español mexicano. En lugar de buscar frases exactas, extrae señales léxicas normalizadas que alimentan los mismos features y combination rules de v4.",
    "architecture": "lexicon-based normalization → feature extraction → combination rules (same pattern as v4)",
    "pipeline_position": "Tier 0 — corre ANTES de v3/v4. Normaliza texto y además puede activar features propios que se suman al scoring de v4.",
    "compatible_with": [
      "sentinel_dataset_v3.json",
      "sentinel_dataset_v4.json"
    ],
    "design_principle": "Componentes pequeños + independientes. Cualquier combinación nueva de componentes conocidos es detectada automáticamente. Sin frases hardcodeadas.",
    "processing_order": [
      "1. lowercase + strip puntuación excesiva",
      "2. normalize_unicode",
      "3. expand_emojis_symbols",
      "4. expand_chat_abbreviations (word boundary)",
      "5. apply_phonetic_rules (ordered)",
      "6. apply_lexicon_matching → extract N0_features",
      "7. apply_N0_combination_rules → bonus scores",
      "8. pass normalized text + N0 features → Tier 1 (v3/v4)"
    ],
    "last_updated": "2026-04-25"
  },
