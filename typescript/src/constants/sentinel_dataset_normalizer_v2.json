  "negation_rules": {
    "description": "Qué hacer cuando una frase está negada. Crítico para no generar falsos negativos ni falsos positivos.",
    "rules": [
      {
        "pattern": "no hay (lana|varo|feria|dinero|chamba|jale)",
        "signal_effect": "CANCEL — negación real del concepto",
        "example": "no hay lana → no activa money_mention"
      },
      {
        "pattern": "no le digas|no le cuentes|no digas nada",
        "signal_effect": "KEEP — la negación ES la señal de secreto",
        "example": "no le digas nada → activa N0-F007"
      },
      {
        "pattern": "no seas (rajon|cagon|gallina|miedoso|culero)",
        "signal_effect": "KEEP — la negación con cobardía ES presión social",
        "example": "no seas rajon → activa N0-F008"
      },
      {
        "pattern": "no pasa nada|no hay pedo|no hay bronca",
        "signal_effect": "KEEP — negación del riesgo ES minimización",
        "example": "no pasa nada → activa N0-F009"
      },
      {
        "pattern": "no te preocupes|no te apures|no tengas miedo",
        "signal_effect": "KEEP — tranquilización activa es minimización",
        "example": "no te preocupes → activa N0-F009"
      }
    ]
  },
