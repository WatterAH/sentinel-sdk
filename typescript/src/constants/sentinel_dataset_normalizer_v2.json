    "phonetic_rules": {
      "description": "Aplicar en orden. Cada regla transforma el texto para que palabras escritas fonéticamente sean reconocibles por los lexicons.",
      "apply_order": "sequential",
      "rules": [
        {
          "id": "PH-01",
          "find": "ph",
          "replace": "f",
          "example": "phono→fono"
        },
        {
          "id": "PH-02",
          "find": "k",
          "replace": "qu",
          "example": "pakete→paquete, ke→que",
          "scope": "before_e_i"
        },
        {
          "id": "PH-03",
          "find": "k",
          "replace": "c",
          "example": "kasa→casa, komer→comer",
          "scope": "before_a_o_u"
        },
        {
          "id": "PH-11",
          "find": "([aeiou])\\1+",
          "replace": "\\1",
          "example": "noooo→no — vocales repetidas énfasis"
        },
        {
          "id": "PH-12",
          "find": "([^aeiou])\\1{2,}",
          "replace": "\\1",
          "example": "mandddar→mandar"
        },
        {
          "id": "PH-13",
          "find": "w",
          "replace": "hu",
          "example": "weno→hueno→bueno"
        },
        {
          "id": "PH-14",
          "find": "g([ei])",
          "replace": "j\\1",
          "example": "gente→jente — confusión g/j",
          "direction": "bidirectional"
        },
        {
          "id": "PH-15",
          "find": "tanb",
          "replace": "tamb",
          "example": "tanbien→tambien"
        },
        {
          "id": "PH-16",
          "find": "conp",
          "replace": "comp",
          "example": "conpra→compra"
        },
        {
          "id": "PH-17",
          "find": "([a-z])iar\\b",
          "replace": "\\1ear",
          "example": "balaciar→balacear, plomiar→plomear"
        },
        {
          "id": "PH-18",
          "find": "ao\\b",
          "replace": "ado",
          "example": "mandao→mandado — recuperar -d- final"
        }
      ]
    },
    "fuzzy_config": {
      "description": "Para términos de los lexicons N0 (abajo), aplicar matching difuso con estos umbrales.",
      "thresholds": [
        {
          "term_length": "5-6",
          "max_levenshtein": 1
        },
        {
          "term_length": "7-8",
          "max_levenshtein": 1
        },
        {
          "term_length": "9+",
          "max_levenshtein": 2
        }
      ],
      "never_fuzzy_length_below": 5,
      "false_positive_guard": [
        {
          "risky_term": "maleta",
          "collides_with": "paleta",
          "action": "exclude"
