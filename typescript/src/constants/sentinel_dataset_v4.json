{
  "metadata": {
    "name": "SENTINEL MX Dataset v4 — Hybrid Feature Engine",
    "version": "4.0.0",
    "description": "Dataset híbrido para Tier 1. Complementa a v3 (regex legacy). Agrega lexicones base, features abstractas y reglas de combinación para detectar mensajes ambiguos que v3 no captura por depender de frases exactas.",
    "compatible_with": "sentinel_dataset_v3.json",
    "architecture": "lexicon-based feature extraction + combination rules",
    "last_updated": "2026-04-25-collision-pass"
  },
  "explicit_signals": [
    {
      "id": "EX-001",
      "label": "transporte_ofrecido",
      "patterns": [
        "te mandamos uber",
        "te mandamos carro",
        "mandamos transporte",
        "te recogemos en",
        "pasa un carro por ti"
      ],
      "weight": 9,
      "category": "logistica_fisica",
      "context_note": "Oferta de transporte no solicitado por desconocido. Señal documental alta."
    },
    {
      "id": "EX-002",
      "label": "secreto_parental",
      "patterns": [
        "que no sepa tu mama",
        "que no sepa tu papa",
        "no le digas a tus papas",
        "no le digas a tus jefes",
        "tus papas no tienen que saber",
        "sin que sepan tus papas"
      ],
      "weight": 10,
      "category": "aislamiento",
      "context_note": "Instrucción explícita de ocultar información a padres. Señal crítica."
    },
    {
      "id": "EX-003",
      "label": "reclutamiento_directo",
      "patterns": [
        "quieres ganar dinero facil",
        "quieres ganar lana facil",
        "ganar dinero sin trabajar",
        "lana sin esfuerzo"
      ],
      "weight": 8,
      "category": "reclutamiento",
      "context_note": "Oferta directa de dinero fácil sin actividad legítima especificada."
    },
    {
      "id": "EX-004",
      "label": "cruce_material",
      "patterns": [
        "cruzar el paquete",
        "cruzar el material",
        "pasar el bulto",
        "cruzar la linea con",
        "hacer el cruce"
      ],
      "weight": 9,
      "category": "logistica_fisica",
      "context_note": "Referencia a cruce de material ilícito. Señal documental de tráfico."
    },
    {
      "id": "EX-005",
      "label": "policia_corrupta",
      "patterns": [
        "la policia no llega",
        "aqui no llega la ley",
        "estan arreglados",
        "estan comprados",
        "la tira esta de nuestro lado",
        "aqui mandamos nosotros"
      ],
      "weight": 9,
      "category": "contenido_normalizado",
      "context_note": "Normalización de corrupción policial. Señal alta documental."
    }
  ],
