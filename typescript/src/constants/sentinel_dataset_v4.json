  "features": [
    {
      "id": "F001",
      "name": "ambiguous_opportunity",
      "weight": 1,
      "description": "Mensaje contiene referencia vaga a oportunidad/actividad sin especificar qué (generic_objects o opportunity_words detectados).",
      "derived_from": [
        "generic_objects",
        "opportunity_words"
      ]
    },
    {
      "id": "F002",
      "name": "call_to_action",
      "weight": 1,
      "description": "Mensaje contiene CTA mexicano (¿jalas?, ¿le entras?, ¿te animas?, ¿o qué?).",
      "derived_from": [
        "cta"
      ]
    },
    {
      "id": "F003",
      "name": "low_specificity",
      "weight": 1,
      "description": "Mensaje NO menciona lugar/actividad concretos. Solo se activa si ya hay ambiguous_opportunity o call_to_action.",
      "derived_from": [
        "concrete_places",
        "concrete_activities"
      ],
      "logic": "NEGATED — se activa cuando NO hay match"
    },
    {
      "id": "F004",
      "name": "money_mention",
      "weight": 2,
      "description": "Referencia a dinero/pago sin contexto laboral verificable.",
      "derived_from": [
        "money_words"
      ]
    },
    {
      "id": "F005",
      "name": "secrecy_pressure",
      "weight": 3,
      "description": "Instrucción de secreto o aislamiento de adultos supervisores.",
      "derived_from": [
        "secrecy_words"
      ]
    },
    {
      "id": "F006",
      "name": "social_pressure",
      "weight": 2,
      "description": "Presión de grupo, desafío de valentía o masculinidad.",
      "derived_from": [
        "pressure_words"
      ]
    },
    {
      "id": "F007",
      "name": "risk_minimization",
      "weight": 2,
      "description": "Minimización activa del riesgo o esfuerzo requerido.",
      "derived_from": [
        "minimization_words"
      ]
    },
    {
      "id": "F008",
      "name": "logistics_transfer",
      "weight": 4,
      "description": "Mensaje implica transporte o entrega de objetos físicos (paquete, bulto, mercancía).",
      "derived_from": [
        "objects_of_risk",
        "delivery_verbs"
      ]
    },
    {
      "id": "F009",
      "name": "cartel_mention",
      "weight": 5,
      "description": "Mención explícita de grupos armados, carteles o figuras delictivas conocidas.",
      "derived_from": [
        "cartel_words"
      ]
    },
    {
      "id": "F010",
      "name": "violence_mention",
      "weight": 20,
      "description": "Mención de violencia física, daño o asesinato. El peso tan elevado desencadena alerta CRÍTICA automática sin necesidad de más contexto.",
      "derived_from": [
        "harm_verbs"
      ]
    },
    {
      "id": "F011",
      "name": "coercion_threat",
      "weight": 3,
      "description": "Lenguaje coercitivo o amenaza condicional.",
      "derived_from": [
        "coercion_words"
      ]
    }
  ],
  "combination_rules": [
    {
      "id": "CR-001",
      "name": "Oportunidad vaga + CTA",
      "features_required": [
        "ambiguous_opportunity",
        "call_to_action"
      ],
      "bonus_score": 5,
      "action": "ESCALATE",
      "description": "Alguien ofrece algo vago y pide participación directa. Patrón: 'salió algo, ¿jalas?'"
    },
    {
      "id": "CR-002",
      "name": "Oportunidad vaga + CTA + baja especificidad",
      "features_required": [
        "ambiguous_opportunity",
        "call_to_action",
        "low_specificity"
      ],
      "bonus_score": 8,
      "action": "ESCALATE",
      "description": "Triple señal: oferta vaga + invitación + cero detalles concretos. El mensaje no tiene nada que reduzca la ambigüedad."
    },
    {
      "id": "CR-003",
      "name": "Dinero + CTA",
      "features_required": [
        "money_mention",
        "call_to_action"
      ],
      "bonus_score": 6,
      "action": "ESCALATE",
      "description": "Mención de dinero + invitación directa sin contexto laboral. Patrón: 'hay lana ¿le entras?'"
    },
    {
      "id": "CR-004",
      "name": "Secreto + Oportunidad",
      "features_required": [
        "secrecy_pressure",
        "ambiguous_opportunity"
      ],
      "bonus_score": 10,
      "action": "ESCALATE",
      "description": "Petición de secreto combinada con oferta vaga. Señal alta de operación encubierta."
    },
    {
      "id": "CR-005",
      "name": "Presión social + CTA",
      "features_required": [
        "social_pressure",
        "call_to_action"
      ],
      "bonus_score": 8,
      "action": "ESCALATE",
      "description": "Presión de pares + invitación directa. Patrón de captación colectiva."
    },
    {
      "id": "CR-006",
      "name": "Dinero + Oportunidad + Minimización",
      "features_required": [
        "money_mention",
        "ambiguous_opportunity",
        "risk_minimization"
      ],
      "bonus_score": 10,
      "action": "ESCALATE",
      "description": "Tríada completa de enganche: oferta económica + actividad vaga + 'es fácil'. Patrón documental de reclutamiento."
    },
    {
      "id": "CR-007",
      "name": "Secreto + Presión social",
      "features_required": [
        "secrecy_pressure",
        "social_pressure"
      ],
      "bonus_score": 12,
      "action": "ESCALATE",
      "description": "Presión de grupo + silencio impuesto. Señal crítica de control psicológico."
    },
    {
      "id": "CR-008",
      "name": "Logística de transporte activa",
      "features_required": [
        "logistics_transfer"
      ],
      "bonus_score": 10,
      "action": "ESCALATE",
      "description": "Mención explícita de mover paquetes o mercancía. Acción de riesgo inmediato."
    },
    {
      "id": "CR-009",
      "name": "Mención de Cartel + Oportunidad/CTA",
      "features_required": [
        "cartel_mention"
      ],
      "bonus_score": 15,
      "action": "ESCALATE",
      "description": "Se menciona un cartel o facción armada. Es una señal crítica que anula cualquier ambigüedad."
    },
    {
      "id": "CR-010",
      "name": "Violencia + CTA",
      "features_required": [
        "violence_mention",
        "call_to_action"
      ],
      "bonus_score": 10,
      "action": "ESCALATE",
      "description": "Reclutamiento forzado o coacción para actuar. (e.g. 'al que no jala le damos su calentada')"
    },
    {
      "id": "CR-011",
      "name": "Violencia + Amenaza condicional",
      "features_required": [
        "violence_mention",
        "coercion_threat"
      ],
      "bonus_score": 12,
      "action": "ESCALATE",
      "description": "Amenaza física directa (e.g. 'te vamos a tronar si no')."
    },
    {
      "id": "CR-012",
      "name": "Violencia + Cartel",
      "features_required": [
        "violence_mention",
        "cartel_mention"
      ],
      "bonus_score": 15,
      "action": "ESCALATE",
      "description": "Glorificación o amenaza explícita del crimen organizado."
    }
  ]
}