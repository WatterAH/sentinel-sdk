{
  "name": "@sentinel-sdk/typescript",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "description": "The Standard for Child Safety in Mexico - TS SDK",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "homepage": "https://watterah.github.io/sentinel-docs/",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "vitest run benchmark/bench.test.ts",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "bench:adversarial": "vitest run benchmark/adversarial.test.ts",
    "export:dataset": "vitest run benchmark/export-dataset.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}